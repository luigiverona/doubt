#!/usr/bin/env bash
set -euo pipefail
export PYTHONDONTWRITEBYTECODE=1

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

[[ $# -eq 2 ]] || {
    printf 'usage: release/publish TAG ASSET_DIRECTORY\n' >&2
    exit 2
}
TAG=$1
ASSETS=$2
REPOSITORY=${GITHUB_REPOSITORY:-luigiverona/doubt}
VERSION=$(cd "$ROOT" && python3 -c 'from doubt.core.version import VERSION; print(VERSION)')
[[ "$TAG" == "$VERSION" ]] || {
    printf 'refusing unexpected release tag: %s\n' "$TAG" >&2
    exit 2
}
[[ -n "${GH_TOKEN:-}" ]] || {
    printf 'GH_TOKEN is required\n' >&2
    exit 2
}

ARCHIVE_NAME="doubt-$VERSION-x86_64.tar.gz"
readonly -a EXPECTED=(COMPONENTS.json SHA256SUMS "$ARCHIVE_NAME" release-members.txt)
[[ -d "$ASSETS" && ! -L "$ASSETS" ]] || {
    printf 'release asset directory is unsafe\n' >&2
    exit 2
}
mapfile -t actual < <(find "$ASSETS" -mindepth 1 -maxdepth 1 -printf '%f\n' | sort)
[[ "${actual[*]}" == "${EXPECTED[*]}" ]] || {
    printf 'release asset allowlist differs: %s\n' "${actual[*]}" >&2
    exit 2
}
for name in "${EXPECTED[@]}"; do
    [[ -f "$ASSETS/$name" && ! -L "$ASSETS/$name" ]] || {
        printf 'release asset is unsafe: %s\n' "$name" >&2
        exit 2
    }
done
(cd "$ASSETS" && sha256sum --check --strict SHA256SUMS)

if ! gh release view "$TAG" --repo "$REPOSITORY" >/dev/null 2>&1; then
    gh release create "$TAG" --repo "$REPOSITORY" --verify-tag \
        --title "doubt $VERSION" --notes-file "$ROOT/release/notes.md"
fi

verify_remote_asset() {
    local name=$1 expected_digest=$2 expected_size=$3 remote_digest='' remote_size=''
    local attempt
    for attempt in {1..10}; do
        remote_digest=$(gh api "repos/$REPOSITORY/releases/tags/$TAG" \
            --jq ".assets[] | select(.name == \"$name\") | .digest // empty")
        remote_size=$(gh api "repos/$REPOSITORY/releases/tags/$TAG" \
            --jq ".assets[] | select(.name == \"$name\") | .size")
        if [[ -n "$remote_digest" && "$remote_digest" != "sha256:$expected_digest" ]]; then
            printf 'published release asset digest differs: %s\n' "$name" >&2
            return 1
        fi
        if [[ "$remote_digest" == "sha256:$expected_digest" && "$remote_size" == "$expected_size" ]]; then
            return 0
        fi
        sleep 2
    done
    printf 'published release asset metadata was not ready: %s\n' "$name" >&2
    return 1
}

for name in "${EXPECTED[@]}"; do
    path="$ASSETS/$name"
    local_digest=$(sha256sum -- "$path")
    local_digest=${local_digest%% *}
    local_size=$(stat -c '%s' -- "$path")
    remote_name=$(gh api "repos/$REPOSITORY/releases/tags/$TAG" \
        --jq ".assets[] | select(.name == \"$name\") | .name")
    if [[ -n "$remote_name" ]]; then
        remote_digest=$(gh api "repos/$REPOSITORY/releases/tags/$TAG" \
            --jq ".assets[] | select(.name == \"$name\") | .digest // empty")
        [[ -z "$remote_digest" || "$remote_digest" == "sha256:$local_digest" ]] || {
            printf 'existing release asset digest differs: %s\n' "$name" >&2
            exit 1
        }
    else
        gh release upload "$TAG" "$path" --repo "$REPOSITORY"
    fi
    verify_remote_asset "$name" "$local_digest" "$local_size"
done

mapfile -t remote_names < <(
    gh api "repos/$REPOSITORY/releases/tags/$TAG" --jq '.assets[].name' | sort
)
[[ "${remote_names[*]}" == "${EXPECTED[*]}" ]] || {
    printf 'published release asset allowlist differs: %s\n' "${remote_names[*]}" >&2
    exit 1
}

VERIFY=$(mktemp -d "${RUNNER_TEMP:-/tmp}/doubt-public-release.XXXXXXXX")
cleanup() {
    case "$VERIFY" in
        "${RUNNER_TEMP:-/tmp}"/doubt-public-release.*)
            [[ -d "$VERIFY" && ! -L "$VERIFY" ]] && rm -rf -- "$VERIFY"
            ;;
    esac
}
trap cleanup EXIT HUP INT TERM
for name in "${remote_names[@]}"; do
    url=$(gh api "repos/$REPOSITORY/releases/tags/$TAG" \
        --jq ".assets[] | select(.name == \"$name\") | .browser_download_url")
    curl --fail --silent --show-error --location --proto '=https' --proto-redir '=https' \
        --retry 4 --retry-all-errors --retry-delay 2 --output "$VERIFY/$name" "$url"
    cmp -- "$ASSETS/$name" "$VERIFY/$name"
done
(cd "$VERIFY" && sha256sum --check --strict SHA256SUMS)
printf 'GitHub Release assets published and independently verified\n'
